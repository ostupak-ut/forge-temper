# secrets-guard — never commit credentials, even if dropped under a bundled dir.
# NOTE: this does NOT ignore server/skills/bundled/ itself; that tree MUST be
# committed so the app runs with no ~/.claude/skills install.
**/.credentials.json
**/*.key
**/.env

# license signing keys (the PRIVATE key must NEVER be committed or shipped) +
# issued licenses + Electron packaging output.
.secrets/
*.license
dist-electron/
release/
